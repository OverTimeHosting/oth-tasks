{
  "name": "oth-tasks",
  "version": "0.1.3",
  "description": "OTHCanva CLI and MCP server. Connects a GitHub repo to the OTHCanva task tracker and exposes task tools to AI agents over MCP.",
  "type": "module",
  "license": "MIT",
  "author": "OverTimeHosting",
  "homepage": "https://github.com/OverTimeHosting/oth-tasks#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/OverTimeHosting/oth-tasks.git"
  },
  "bugs": {
    "url": "https://github.com/OverTimeHosting/oth-tasks/issues"
  },
  "keywords": [
    "oth",
    "othcanva",
    "mcp",
    "tasks",
    "agents",
    "claude"
  ],
  "bin": {
    "oth": "./dist/index.js",
    "oth-mcp": "./bin/oth-mcp.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.0.0",
    "open": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
